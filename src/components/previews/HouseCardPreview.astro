---
interface Props {
  size?: 'tile' | 'hero';
}
const { size = 'tile' } = Astro.props;
const isHero = size === 'hero';
---

<div class={`hc-preview${isHero ? ' hc-hero' : ''}`}>
  <svg class="hc-svg" viewBox="0 0 260 180" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <!-- Background -->
    <rect width="260" height="180" fill="#0a0e14" rx="4"/>

    <!-- Floor 2 — upper storey (offset up and right) -->
    <!-- Room: Bedroom (lit, warm white) -->
    <g class="hc-room hc-lit">
      <!-- top face -->
      <polygon points="100,28 148,28 148,68 100,68" fill="#2a1f0e" stroke="#4a3520" stroke-width="0.5"/>
      <!-- right wall -->
      <polygon points="148,28 160,38 160,78 148,68" fill="#1e1608" stroke="#4a3520" stroke-width="0.5"/>
      <!-- left wall -->
      <polygon points="100,28 112,38 112,78 100,68" fill="#221b0c" stroke="#4a3520" stroke-width="0.5"/>
      <!-- glow on top face -->
      <polygon points="100,28 148,28 148,68 100,68" fill="url(#warmGlow)" opacity="0.55"/>
      <!-- floor glow ellipse -->
      <ellipse cx="124" cy="80" rx="32" ry="7" fill="#f59e0b" opacity="0.10"/>
      <ellipse cx="124" cy="80" rx="20" ry="4" fill="#f59e0b" opacity="0.18"/>
      <!-- label -->
      <text x="124" y="52" text-anchor="middle" font-size="6" fill="#d4a55a" font-family="monospace">Bedroom</text>
    </g>

    <!-- Room: Office (unlit) -->
    <g class="hc-room hc-dark">
      <polygon points="148,28 196,28 196,68 148,68" fill="#111827" stroke="#1e2535" stroke-width="0.5"/>
      <polygon points="196,28 208,38 208,78 196,68" fill="#0d1420" stroke="#1e2535" stroke-width="0.5"/>
      <polygon points="148,28 160,38 160,78 148,68" fill="#0f1825" stroke="#1e2535" stroke-width="0.5"/>
      <text x="172" y="52" text-anchor="middle" font-size="6" fill="#3a4a5a" font-family="monospace">Office</text>
    </g>

    <!-- Floor 1 — ground floor (lower) -->
    <!-- Room: Lounge (lit, blue-white) -->
    <g class="hc-room hc-lit">
      <polygon points="60,88 120,88 120,138 60,138" fill="#0d1a2e" stroke="#1a3a5a" stroke-width="0.5"/>
      <polygon points="120,88 134,100 134,150 120,138" fill="#091426" stroke="#1a3a5a" stroke-width="0.5"/>
      <polygon points="60,88 74,100 74,150 60,138" fill="#0b1830" stroke="#1a3a5a" stroke-width="0.5"/>
      <polygon points="60,88 120,88 120,138 60,138" fill="url(#blueGlow)" opacity="0.5"/>
      <ellipse cx="90" cy="152" rx="38" ry="8" fill="#60a5fa" opacity="0.10"/>
      <ellipse cx="90" cy="152" rx="22" ry="4.5" fill="#60a5fa" opacity="0.22"/>
      <text x="90" y="112" text-anchor="middle" font-size="6" fill="#7ab8f5" font-family="monospace">Lounge</text>
      <!-- occupancy icon -->
      <circle cx="90" cy="123" r="4" fill="none" stroke="#60a5fa" stroke-width="0.8" opacity="0.7"/>
      <line x1="90" y1="127" x2="90" y2="133" stroke="#60a5fa" stroke-width="0.8" opacity="0.7"/>
      <line x1="87" y1="129" x2="93" y2="129" stroke="#60a5fa" stroke-width="0.8" opacity="0.7"/>
    </g>

    <!-- Room: Kitchen (lit, warm) -->
    <g class="hc-room hc-lit">
      <polygon points="120,88 178,88 178,138 120,138" fill="#1e1508" stroke="#3a2a10" stroke-width="0.5"/>
      <polygon points="178,88 192,100 192,150 178,138" fill="#160f05" stroke="#3a2a10" stroke-width="0.5"/>
      <polygon points="120,88 134,100 134,150 120,138" fill="#1a1206" stroke="#3a2a10" stroke-width="0.5"/>
      <polygon points="120,88 178,88 178,138 120,138" fill="url(#warmGlow)" opacity="0.4"/>
      <ellipse cx="149" cy="152" rx="38" ry="8" fill="#fbbf24" opacity="0.10"/>
      <ellipse cx="149" cy="152" rx="22" ry="4.5" fill="#fbbf24" opacity="0.20"/>
      <text x="149" y="108" text-anchor="middle" font-size="6" fill="#d4a55a" font-family="monospace">Kitchen</text>
      <!-- temp reading -->
      <text x="149" y="120" text-anchor="middle" font-size="5.5" fill="#a07a3a" font-family="monospace">21.4°</text>
    </g>

    <!-- Room: Hallway (dark) -->
    <g class="hc-room hc-dark">
      <polygon points="178,88 220,88 220,138 178,138" fill="#0e1520" stroke="#1a2030" stroke-width="0.5"/>
      <polygon points="220,88 234,100 234,150 220,138" fill="#0a1018" stroke="#1a2030" stroke-width="0.5"/>
      <polygon points="178,88 192,100 192,150 178,138" fill="#0c1220" stroke="#1a2030" stroke-width="0.5"/>
      <text x="199" y="118" text-anchor="middle" font-size="6" fill="#2a3a4a" font-family="monospace">Hall</text>
    </g>

    <!-- Gradient defs -->
    <defs>
      <radialGradient id="warmGlow" cx="50%" cy="50%" r="60%">
        <stop offset="0%" stop-color="#fbbf24" stop-opacity="0.35"/>
        <stop offset="100%" stop-color="#f59e0b" stop-opacity="0"/>
      </radialGradient>
      <radialGradient id="blueGlow" cx="50%" cy="50%" r="60%">
        <stop offset="0%" stop-color="#93c5fd" stop-opacity="0.35"/>
        <stop offset="100%" stop-color="#3b82f6" stop-opacity="0"/>
      </radialGradient>
    </defs>

    {isHero && (
      <>
        <!-- Hero: add heatmap-style temp overlay strip -->
        <rect x="8" y="160" width="244" height="12" rx="2" fill="#111827" opacity="0.8"/>
        <text x="14" y="169" font-size="5.5" fill="#60a5fa" font-family="monospace">axonometric · 2 floors · 4 rooms · heatmap</text>
      </>
    )}
  </svg>
</div>
